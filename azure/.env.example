# InteractHub Azure Environment Configuration

## Azure Subscription
AZURE_SUBSCRIPTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

## Resource Group & Region
AZURE_REGION=eastus
RESOURCE_GROUP_NAME=interacthub-rg-staging

## Application Configuration
APP_NAME=interacthub
ENVIRONMENT=staging
APP_SERVICE_SKU=B2

## SQL Database
SQL_SERVER_NAME=interacthub-sql-xxxxxx
SQL_DATABASE_NAME=InteractHub_staging
SQL_ADMIN_USERNAME=sqladmin
SQL_ADMIN_PASSWORD=YourSecurePassword123!

## Storage Account
STORAGE_ACCOUNT_NAME=interacthubstoragestaging
STORAGE_CONTAINER=uploads

## Key Vault
KEY_VAULT_NAME=interacthub-kv-staging

## Application Insights
APP_INSIGHTS_NAME=interacthub-insights-staging
INSTRUMENTATION_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

## JWT Configuration
JWT_KEY=GeneratedSecureKeyHere
JWT_ISSUER=https://interacthub-api-staging.azurewebsites.net
JWT_AUDIENCE=InteractHub
JWT_EXPIRATION_MINUTES=1440

## CORS Configuration
CORS_ALLOWED_ORIGINS=https://interacthub-staging.azurewebsites.net,http://localhost:3000,http://localhost:5173

## Deployment Configuration
DEPLOY_BRANCH=develop
CI_CD_PROVIDER=github-actions
AUTO_DEPLOY=true

## Monitoring & Logging
LOG_LEVEL=Information
ENABLE_APP_INSIGHTS=true
ENABLE_SQL_AUDIT=true
RETENTION_DAYS=90

## Backup Configuration
AUTO_BACKUP_ENABLED=true
BACKUP_FREQUENCY=daily
BACKUP_RETENTION_DAYS=30
